<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of all Products</title>
</head>
<body>
    <article>
        <% Products.forEach((data) => { %>
            <div>
                <img src="<%= data.url %>" alt="" height="100">
                <h1>Name: <%= data.Pname %></h1>
                <h2>Price: ₹<%= data.P_price %></h2>
                <aside>
                    <button><a href="#">Show</a></button>
                    <button><a href="#">Edit</a></button>
                    <button><a href="#">Delete</a></button>
                </aside>
            </div>
        <% }) %>
    </article>
</body>
</html>